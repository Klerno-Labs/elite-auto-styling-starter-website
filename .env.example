# Copy this file to .env.local and fill in the real values.

# -------------------------------------------------------------------
# FORM HANDLING
# -------------------------------------------------------------------
# This is the endpoint where the contact form sends data.
# For static sites, we recommend using a service like Formspree (free tier available).
# Example: https://formspree.io/f/your-form-id
NEXT_PUBLIC_CONTACT_FORM_URL="https://formspree.io/f/your-form-id"

# -------------------------------------------------------------------
# ANALYTICS (Optional)
# -------------------------------------------------------------------
# If using Google Analytics, paste your Measurement ID here.
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# -------------------------------------------------------------------
# MAPS API (Optional)
# -------------------------------------------------------------------
# If you want to replace the static map image with a real interactive Google Map,
# generate a key at https://developers.google.com/maps/documentation/javascript/get-api-key
# NEXT_PUBLIC_GOOGLE_MAPS_KEY="your-api-key-here"